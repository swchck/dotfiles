            'message': 'Do you want to configurate git for Work and Personal use?',
            'default': False
        },
        {
            'type': 'input',
            'name': 'personal_git_username',
            'message': 'Please type your *personal* git username',
            'filter': lambda val: val.lower(),  # type: str
            'when': lambda data: data['git_config'] is True
        },
        {
            'type': 'input',
            'name': 'personal_git_email',
            'message': 'Please type your *personal* git email',
            'filter': lambda val: val.lower(),  # type: str
            'when': lambda data: data['git_config'] is True
        },
        {
            'type': 'input',
            'name': 'work_git_username',
            'message': 'Please type your *work* git username',
            'filter': lambda val: val.lower(),  # type: str
            'when': lambda data: data['git_config'] is True
        },
        {
            'type': 'input',
            'name': 'work_git_email',
            'message': 'Please type your *work* git email',
            'filter': lambda val: val.lower(),  # type: str
            'when': lambda data: data['git_config'] is True
        },
    ]

    print(f"{Bcolors.FAIL}{logo}{Bcolors.END_C}")
    install(prompt(questions=questions))
