#!/bin/python3

import os
import json
import platform
import subprocess

from PyInquirer import prompt
from github import Github

logo = """
        ▓█████▄   ▒█████   ▄▄▄█████▓  █████▒   ██▓  ██▓     ▓█████    ██████ 
        ▒██▀ ██▌ ▒██▒  ██▒▓   ██▒   ▓▒▓██   ▒ ▓██▒▓ ██▒     ▓█   ▀  ▒██    ▒ 
        ░██   █▌ ▒██░  ██▒▒  ▓██░   ▒░▒████ ░ ▒██▒▒ ██░     ▒███    ░ ▓██▄   
        ░▓█▄   ▌ ▒██   ██░░  ▓██▓   ░ ░▓█▒  ░ ░██░▒ ██░     ▒▓█  ▄    ▒   ██▒
    ██▓ ░▒████▓  ░ ████▓▒░   ▒██▒   ░ ░▒█░    ░██░░ ██████▒ ░▒████▒ ▒██████▒▒
    ▒▓▒  ▒▒▓  ▒  ░ ▒░▒░▒░    ▒ ░░      ▒ ░    ░▓  ░  ▒░▓  ░ ░░ ▒░ ░ ▒ ▒▓▒ ▒ ░
    ░▒   ░ ▒  ▒    ░ ▒ ▒░      ░       ░       ▒ ░░  ░ ▒  ░  ░ ░  ░ ░ ░▒  ░ ░
    ░    ░ ░  ░  ░ ░ ░ ▒     ░         ░ ░     ▒ ░   ░ ░       ░    ░  ░  ░  
     ░     ░         ░ ░                       ░       ░  ░    ░  ░       ░  
     ░   ░                                                                                                                        
 """

github_link = "https://github.com/settings/tokens/new?description=Dotfiles&scopes=repo%2Cgist%2Cread%2Cuser"
auth_message = "Please paste github access token. Token will be used for repo creation.\n" + \
               "You can generate token with granular permissions by the link: {}\n".format(github_link) + \
               "Token:"

with open('data/casks.json') as json_file:
    casks_json = json.load(json_file)
with open('data/cli_utils.json') as json_file:
    cli_utils_json = json.load(json_file)

# Get Platform name
platform_name = platform.system().lower()


class Bcolors:
    HEADER = '\033[95m'
    OK_BLUE = '\033[94m'
    OK_CYAN = '\033[96m'
    OK_GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    END_C = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'


def get_textarea_question(name: str, message: str, ext: str):
    return {
        'type': 'editor',
        'name': name,
        'message': message,
        'default': '<You can paste file content here>',
        'eargs': {
            'editor': "vi",
            'ext': '.{}'.format(ext)
        }
    }


def get_choices_from_file(items: list[dict]):
    choices = []
    for item in items:
        unsupported = item.get('unsupported')  # type: list
        choices.append({
            'name': item.get('name'),
            'value': item.get('id'),
            'disabled': "" if unsupported.__contains__(platform_name) else ""
        })
    return choices


def brew_install(names: list[str], cask=False):
    for name in names:
        if cask:
            casks_list = subprocess.check_output('brew list -1 --casks', shell=True).decode("utf-8").split()
            if not casks_list.__contains__(cask):
                os.system("brew install -q --cask {name}".format(name=cask))
            else:
                print("{} already installed, Skipping...".format(name.capitalize()))
        else:
            if os.system('which -s {}'.format(name)) != 0:
                os.system("brew install -q {name}".format(name=name))
            else:
                print("{} already installed, Skipping...".format(name.capitalize()))


def git_clone(url: str, path: str):
    os.system("git clone {} {}".format(url, path))


def create_github_repo():
    github_answers = prompt(questions=[
        {
            "type": "list",
            "name": "repo_creation",
            "message": "Create repository with token or Provide Clone URL",
            "choices": [{"name": "Token", "value": "token"}, {"name": "Existed repository URL", "value": "repo"}]
        },
        {
            "type": "input",
            "name": "token",
            "message": auth_message,
            "when": lambda data: data['repo_creation'] == 'token'
        },
        {
            "type": "input",
            "name": "repo_url",
            "message": "Paste Repo URL",
            "when": lambda data: data['repo_creation'] == 'repo'
        }
    ])

    if github_answers.get('repo_creation') == 'token':
        github_user = Github(github_answers.get("token")).get_user()

        for repo in github_user.get_repos():
            if repo.name == "dotfiles":
                git_clone(repo.clone_url, "~/dotfiles")
            else:
                git_clone(
                    github_user.create_repo("dotfiles", "dotfiles").clone_url,
                    "~/dotfiles"
                )
    else:
        git_clone(github_answers.get('repo_url'), "~/dotfiles")

    os.chdir("~/dotfiles")


def configure_shell(shell_name: str):
    if os.system('which -s {}'.format(shell_name)) == '':
        os.system('brew install {}'.format(shell_name))
        if shell_name == 'fish':
            os.system('curl https://raw.githubusercontent.com/oh-my-fish/oh-my-fish/master/bin/install | fish')
        elif shell_name == 'zsh':
            os.system('sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"')
    os.system('chsh -s $(which {})'.format(shell_name))


def install(config: dict):
    configure_shell(config.get('shell'))

    brew_install(config.get('cli_utils'))
    brew_install(config.get('casks'), cask=True)

    if config.get('cli_utils').__contains__('tmux'):
        git_clone("https://github.com/tmux-plugins/tpm", "~/.tmux/plugins/tpm")


if __name__ == '__main__':
    os.system('clear')
    questions = [
        {
            'type': 'list',
            'name': 'shell',
            'message': "What shell do you want to use as Default?",
            'choices': [
                {
                    'name': 'Fish - Friendly Interactive Shell',
                    'value': 'fish'
                },
                {
                    'name': 'ZSH',
                    'value': 'zsh',
                    'disabled': 'Not supported 🙁'
                }
            ]
        },
        # Applications chooser
        {
            'type': 'checkbox',
            'name': 'cli_utils',
            'message': 'What CLI util do you need to install?',
            'choices': get_choices_from_file(cli_utils_json)
        },
        {
            'type': 'checkbox',
            'name': 'casks',
            'message': 'What Applications do you need to install?',
            'choices': get_choices_from_file(casks_json)
        }
    ]

    print(f"{Bcolors.FAIL}{logo}{Bcolors.END_C}")
    create_github_repo()
    install(prompt(questions=questions))
