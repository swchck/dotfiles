            'filter': lambda val: val.lower()  # type: str
        },
        {
            'type': 'input',
            'name': 'work_git_username',
            'message': 'Please type your *work* git username (can be empty)',
            'filter': lambda val: val.lower()  # type: str
        },
        {
            'type': 'input',
            'name': 'work_git_email',
            'message': 'Please type your *work* git email (can be empty)',
            'filter': lambda val: val.lower()  # type: str
        }
    ]
    try:
        parser = ArgumentParser('git-config-manager')
    except (ArgumentError, ArgumentTypeError) as e:
        print("")
        return 2


