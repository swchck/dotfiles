#!/bin/python3

import os
import sys

from argparse import ArgumentParser, ArgumentTypeError, ArgumentError


def main():
    try:
        parser = ArgumentParser('local-files-manager')
        parser.add_argument(
            '-d',
            '--delete',
            action='store_true',
            default=False,
            help='Delete $1 file in local-dotfiles folder'
        )
        parser.add_argument(
            '-f',
            metavar='--files',
            type=str,
            nargs='+',
            choices=['git_template', 'gitconfig', 'tmux', 'zsh', 'fish'],
            help="Override remote configuration from your repository"
        )
        arguments = parser.parse_args()
    except (ArgumentTypeError, ArgumentError) as e:
        print('Can\'t parse arguments!', e)
        return 2

    for file_name in arguments.files:
        if arguments.delete:
            os.rmdir('~/dotfiles-local/{}.local'.format(file_name))
        os.mkdir('~/dotfiles-local/{}.local'.format(file_name))

    return 0


if __name__ == '__main__':
    sys.exit(main())
