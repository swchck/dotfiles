# chezmoi ignore rules (supports Go templates)
# These patterns are excluded from chezmoi management

# ── OS-specific scripts ──────────────────────────────────────────────

{{ if ne .chezmoi.os "darwin" }}
# Skip macOS scripts on non-darwin
.chezmoiscripts/darwin/**
{{ end }}

{{ if ne .chezmoi.os "linux" }}
# Skip Linux scripts on non-linux
.chezmoiscripts/linux/**
{{ end }}

# ── macOS-only configs ───────────────────────────────────────────────

{{ if ne .chezmoi.os "darwin" }}
# macOS-specific apps
.config/wezterm
.orbstack
.docker
.config/openfortivpn
{{ end }}

# ── Linux-only configs ───────────────────────────────────────────────

{{ if ne .chezmoi.os "linux" }}
# Linux-specific (none yet, placeholder)
{{ end }}

# ── Ephemeral environments (containers, codespaces) ──────────────────

{{ if .ephemeral }}
# Skip install scripts in containers
.chezmoiscripts/**

# Skip encrypted files (no age key in containers)
.ssh
.netrc

# Skip heavy configs not useful in containers
.config/k9s
.config/ghorg
.config/zellij
.deadbranch
{{ end }}

# ── Headless environments ────────────────────────────────────────────

{{ if .headless }}
# Skip GUI-only configs
.config/zed
.config/gram
.config/wezterm
{{ end }}

# ── Work-specific ────────────────────────────────────────────────────

{{ if ne .machine_type "work" }}
.config/openfortivpn
.config/k9s
.netrc
{{ end }}

# ── Claude Code runtime (never sync) ─────────────────────────────────
# Static config (CLAUDE.md, settings.json, hooks/, skills/, statusline-command.sh)
# IS tracked under src/dot_claude/. Everything below is per-machine state.

.claude/backups
.claude/cache
.claude/file-history
.claude/history.jsonl
.claude/paste-cache
.claude/plans
.claude/plugins
.claude/policy-limits.json
.claude/projects
.claude/remote-settings.json
.claude/session-env
.claude/sessions
.claude/shell-snapshots
.claude/stats-cache.json
.claude/tasks
.claude/telemetry
.claude/claude-dashboard.local.json
.claude/**/.DS_Store
.claude/*.headroom-backup-*

# ── Copilot CLI runtime ──────────────────────────────────────────────
# Only config.json (create-once) tracked under src/dot_copilot/.

.copilot/command-history-state.json
.copilot/logs
.copilot/session-state
