---
# Ghorg — GitLab configuration
# Usage: ghorg clone <org> --config=~/.config/ghorg/gitlab.yaml
{{ if and (eq .machine_type "work") (hasKey . "gitlab") }}
GHORG_SCM_TYPE: gitlab
GHORG_SCM_BASE_URL: https://{{ .gitlab.url }}
GHORG_CLONE_TYPE: org
GHORG_ABSOLUTE_PATH_TO_CLONE_TO: {{ .paths.work }}
GHORG_GITLAB_TOKEN: {{ (decrypt (include ".chezmoitemplates/secrets.toml.age") | fromToml).secrets.ghorg_gitlab_token }}

{{ template "ghorg-common" . }}
{{ else }}
# GitLab not configured on personal machine
# Add work credentials to enable:
#   security add-generic-password -a chezmoi -s ghorg-gitlab-token -w '<TOKEN>'
{{ end -}}
