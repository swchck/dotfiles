# Ghostty 1.3.1 terminal configuration
# https://ghostty.org/docs/config
#
# To reload: Cmd+Shift+, or ghostty +reload-config
# All options: ghostty +show-config --default

# ── Theme & Appearance ───────────────────────────────────────────────

theme = Atom One Dark
background-opacity = 1
window-colorspace = display-p3
window-padding-balance = true
# background-blur = false
# background-image =
# background-image-opacity = 1.0
# background-image-position = center
# background-image-fit = contain
# background-image-repeat = false
# background-opacity-cells = false
# bold-color =
# faint-opacity = 0.5
# minimum-contrast = 1.0
# bold-is-bright = false
# foreground =
# background =

# palette = 0=#000000
# ...

# ── Font ─────────────────────────────────────────────────────────────

font-family = {{ .font.main }}
font-family = {{ .font.fallback }}
# font-family-bold =
# font-family-italic =
# font-family-bold-italic =
# font-style =
# font-style-bold =
# font-style-italic =
# font-style-bold-italic =
# font-synthetic-style = true
# font-codepoint-map =

# OpenType features (Monaspace ligatures & stylistic sets)
font-feature = "+calt"
font-feature = "+ss01"
font-feature = "+ss02"
font-feature = "+ss03"
font-feature = "+ss04"
font-feature = "+ss05"
font-feature = "+ss06"
font-feature = "+ss07"
font-feature = "+ss08"
font-feature = "+ss09"
font-feature = "+ss10"
font-feature = "+liga"
font-feature = "+dlig"

# font-size = 13
# font-thicken = false
# font-thicken-strength = 255
# font-shaping-break = grapheme
# freetype-load-flags = default
# grapheme-width-method = unicode
# alpha-blending = linear

# Font adjustments
# adjust-cell-width =
# adjust-cell-height =
