# k9s 0.50.18
# k9s configuration
# https://k9scli.io/topics/config/
#
# Usage:
#   k9s                   # launch
#   k9s -n <namespace>    # specific namespace
#   k9s --context <ctx>   # specific context
#   k9s --readonly        # read-only mode

k9s:
  # Refresh rate in seconds
  refreshRate: 2

  # API-server reconnect retries
  maxConnRetry: 5

  # Read-only mode
  readOnly: false

  # Don't quit on Ctrl-C
  noExitOnCtrlC: false

  # UI settings (v0.30+ — these keys live under k9s.ui)
  ui:
    # Skin name (loaded from $XDG_DATA_HOME/k9s/skins/<name>.yaml)
    skin: {{ .theme.name | lower | replace " " "-" }}
    # Enable mouse support
    enableMouse: false
    # Headless mode (no header)
    headless: false
    # Hide breadcrumbs
    crumbsless: false
    # Reactive UI
    reactive: true
    # Logo display
    logoless: false
    # No icons
    noIcons: false

  # Logger settings
  logger:
    # Tail log lines
    tail: 100
    # Buffer size
    buffer: 5000
    # Text wrap
    textWrap: false
    # Show timestamp
    showTime: false
    # Since duration
    sinceSeconds: -1

  # Shell pod settings
  # shellPod:
  #   image: busybox:1.35.0
  #   namespace: default
  #   limits:
  #     cpu: 100m
  #     memory: 100Mi
