    options = {
        icons_enabled = true,
        theme = "One Dark (Gogh)",
        theme_overrides = {
            normal_mode = {
                a = { fg = "#282c34", bg = "#61afef" },
                b = { fg = "#61afef", bg = "#3e4452" },
                c = { fg = "#abb2bf", bg = "#282c34" },
            },
            tab = {
                active = { fg = "#61afef", bg = "#3e4452" },
                inactive = { fg = "#abb2bf", bg = "#282c34" },
                inactive_hover = { fg = "#c678dd", bg = "#3e4452" },
            },
        },
        tabs_enabled = true,
        section_separators = "",
        component_separators = "",
        tab_separators = "",
    },
    sections = {
        tabline_a = { "mode" },
        tabline_b = {
