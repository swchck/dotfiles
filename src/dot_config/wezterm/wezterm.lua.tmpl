-- ── Keybindings ─────────────────────────────────────────────────────
--
-- Leader key: Alt+q (2 second timeout), then:
--   |          split right
--   -          split down
--   h/j/k/l   navigate panes
--   Arrow      resize panes
--   c          new tab
--   x          close pane
--   n/b        next/prev tab
--   0-9        go to tab
--   z          toggle zoom
--   f          search
--   s          save session (resurrect)
--   r          restore session (resurrect)
--   w          switch workspace (zoxide fuzzy)
--   W          switch to previous workspace
--
-- Direct shortcuts (no leader):
--   Alt+Arrow  navigate panes
--   Alt+F9     tab navigator

config.leader = { key = "q", mods = "ALT", timeout_milliseconds = 2000 }

config.keys = {
    -- Pane splits (leader + | and -)
    { mods = "LEADER", key = "|", action = act.SplitHorizontal({ domain = "CurrentPaneDomain" }) },
    { mods = "LEADER", key = "-", action = act.SplitVertical({ domain = "CurrentPaneDomain" }) },

    -- Pane navigation — leader + hjkl
    { mods = "LEADER", key = "h", action = act.ActivatePaneDirection("Left") },
    { mods = "LEADER", key = "j", action = act.ActivatePaneDirection("Down") },
    { mods = "LEADER", key = "k", action = act.ActivatePaneDirection("Up") },
    { mods = "LEADER", key = "l", action = act.ActivatePaneDirection("Right") },

    -- Pane navigation — Ctrl+Alt + Arrow
    { key = "LeftArrow",  mods = "CTRL|ALT", action = act.ActivatePaneDirection("Left") },
    { key = "RightArrow", mods = "CTRL|ALT", action = act.ActivatePaneDirection("Right") },
    { key = "UpArrow",    mods = "CTRL|ALT", action = act.ActivatePaneDirection("Up") },
    { key = "DownArrow",  mods = "CTRL|ALT", action = act.ActivatePaneDirection("Down") },

    -- Tab navigation — Cmd + Arrow
    { key = "LeftArrow",  mods = "CMD", action = act.ActivateTabRelative(-1) },
    { key = "RightArrow", mods = "CMD", action = act.ActivateTabRelative(1) },

    -- Pane resize — leader + Arrow
    { mods = "LEADER", key = "LeftArrow",  action = act.AdjustPaneSize({ "Left", 5 }) },
    { mods = "LEADER", key = "RightArrow", action = act.AdjustPaneSize({ "Right", 5 }) },
    { mods = "LEADER", key = "UpArrow",    action = act.AdjustPaneSize({ "Up", 5 }) },
    { mods = "LEADER", key = "DownArrow",  action = act.AdjustPaneSize({ "Down", 5 }) },

    -- Tabs
    { mods = "LEADER", key = "c", action = act.SpawnTab("CurrentPaneDomain") },
    { mods = "LEADER", key = "x", action = act.CloseCurrentPane({ confirm = true }) },
    { mods = "LEADER", key = "n", action = act.ActivateTabRelative(1) },
    { mods = "LEADER", key = "b", action = act.ActivateTabRelative(-1) },

    -- Toggle pane zoom (like tmux prefix+z)
    { mods = "LEADER", key = "z", action = act.TogglePaneZoomState },

    -- Search
    { mods = "LEADER", key = "f", action = act.Search({ CaseInSensitiveString = "" }) },

    -- Tab navigator
    { key = "F9", mods = "ALT", action = act.ShowTabNavigator },

    -- ── Resurrect Plugin ────────────────────────────────────────────
    -- Leader + s: save current workspace state
    -- Leader + r: fuzzy load saved state
    { mods = "LEADER", key = "s", action = wezterm.action_callback(function(win, pane)
        resurrect.state_manager.save_state(resurrect.workspace_state.get_workspace_state())
        resurrect.window_state.save_window_action()
    end) },
    { mods = "LEADER", key = "r", action = wezterm.action_callback(function(win, pane)
        resurrect.fuzzy_loader.fuzzy_load(win, pane, function(id, label)
            local type = string.match(id, "^([^/]+)")
            id = string.match(id, "([^/]+)$")
            id = string.match(id, "(.+)%..+$")
            local opts = {
                relative = true,
                restore_text = true,
                on_pane_restore = resurrect.tab_state.default_on_pane_restore,
            }
            if type == "workspace" then
                local state = resurrect.state_manager.load_state(id, "workspace")
                resurrect.workspace_state.restore_workspace(state, opts)
            elseif type == "window" then
                local state = resurrect.state_manager.load_state(id, "window")
                resurrect.window_state.restore_window(pane:window(), state, opts)
            elseif type == "tab" then
                local state = resurrect.state_manager.load_state(id, "tab")
                resurrect.tab_state.restore_tab(pane:tab(), state, opts)
            end
        end)
    end) },

    -- ── Workspace Switcher Plugin ───────────────────────────────────
    -- Leader + w: fuzzy switch workspace (uses zoxide)
    -- Leader + W: switch to previous workspace
    { mods = "LEADER", key = "w", action = workspace_switcher.switch_workspace() },
    { mods = "LEADER", key = "W", action = workspace_switcher.switch_to_prev_workspace() },
}

-- Leader + 0-9 to activate tabs
for i = 0, 9 do
    table.insert(config.keys, {
        mods = "LEADER",
        key = tostring(i),
        action = act.ActivateTab(i),
    })
end

