// Zed 0.229.0 settings
// https://zed.dev/docs/configuring-zed
//
// To see all defaults: run `open default settings` from the command palette.
// Full reference: https://zed.dev/docs/reference/all-settings
{
  // ── Appearance ──────────────────────────────────────────────────────

  // Theme — supports light/dark mode switching
  "theme": {
    "mode": "dark",
    "dark": "{{ .theme.name }}",
    "light": "One Light"
  },
  // "icon_theme": "Zed (Default)",

  // Cursor
  // "cursor_shape": "bar",            // bar, block, underline, hollow
  // "cursor_blink": true,

  // Current line highlight: none, gutter, line, all (default: "all")
  // "current_line_highlight": "all",

  // Rounded corners on text selection (default: true)
  // "rounded_selection": true,

  // ── Fonts ───────────────────────────────────────────────────────────

  // UI font
  "ui_font_family": ".ZedSans",
  "ui_font_size": 14.0,
  "ui_font_fallbacks": ["{{ .font.fallback }}"],
  "ui_font_features": {
    "calt": true,
    "ss01": true, "ss02": true, "ss03": true, "ss04": true, "ss05": true,
    "ss06": true, "ss07": true, "ss08": true, "ss09": true,
    "liga": true
  },

  // Buffer font
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 13.0,
  // "buffer_font_weight": 400,        // 100-900
  "buffer_font_fallbacks": ["{{ .font.fallback }}"],
  "buffer_font_features": {
    "calt": true,
    "ss01": true, "ss02": true, "ss03": true, "ss04": true, "ss05": true,
    "ss06": true, "ss07": true, "ss08": true, "ss09": true,
    "liga": true
  },
  // "buffer_line_height": "comfortable",  // "comfortable", "standard", {"custom": 1.5}

  // Agent panel font size (default: same as buffer_font_size)
  // "agent_font_size": 13,

  // ── Editor ──────────────────────────────────────────────────────────

  // Save behavior
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  // "remove_trailing_whitespace_on_save": true,
  // "close_on_file_delete": false,

  // Formatter: "auto", "language_server", "external", "prettier"
  // "formatter": "auto",

  // Startup & session
  "auto_update": true,
  "restore_on_startup": "last_workspace",
  // "restore_on_file_reopen": true,

  // Session
  // "session": {
  //   "restore_unsaved_buffers": true,
  //   "trust_all_worktrees": false
  // },

  // Editing
  "use_autoclose": true,
  "selection_highlight": true,
  "unnecessary_code_fade": 0.7,
  // "vim_mode": false,
  // "helix_mode": false,
  // "base_keymap": "VSCode",          // VSCode, JetBrains, Sublime Text, Atom, TextMate
  // "confirm_quit": false,
  // "linked_edits": true,             // linked editing of associated ranges (e.g. HTML tags)
  // "extend_comment_on_newline": true,
  // "always_treat_brackets_as_autoclosed": false,
  // "use_on_type_format": true,
  // "auto_indent": true,
  // "auto_indent_on_paste": true,

  // Window
  "use_system_window_tabs": true,
  "multi_cursor_modifier": "alt",
  // "on_last_window_closed": "platform_default",  // platform_default, quit_app, keep_running

  // Active pane
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 1.0
  },

  // Layout
  // "bottom_dock_layout": "contained",  // contained, full, left_aligned, right_aligned
  // "centered_layout": { "left_padding": 0.2, "right_padding": 0.2 },
  // "pane_split_direction_horizontal": "up",
  // "pane_split_direction_vertical": "left",
  // "drop_target_size": 0.2,

  // ── Gutter & Line Numbers ─────────────────────────────────────────

  // "gutter": {
  //   "line_numbers": true,
  //   "runnables": true,
  //   "breakpoints": true,
  //   "folds": true,
  //   "min_line_number_digits": 4
  // },
  // "relative_line_numbers": "disabled",  // enabled, wrapped, disabled

  // ── Scrollbar & Minimap ───────────────────────────────────────────

  // "scrollbar": {
  //   "show": "auto",                 // auto, system, always, never
  //   "cursors": true,
  //   "git_diff": true,
  //   "search_results": true,
  //   "selected_text": true,
  //   "selected_symbol": true,
  //   "diagnostics": "all",           // all, none, error, warning, information
  //   "axes": { "horizontal": true, "vertical": true }
  // },
  // "minimap": {
  //   "show": "never",                // always, auto, never
  //   "thumb": "always",              // hover, always
  //   "thumb_border": "left_open"
  // },

  // Scroll behavior
  // "scroll_sensitivity": 1.0,
  // "fast_scroll_sensitivity": 4.0,
  // "horizontal_scroll_margin": 5,
  // "vertical_scroll_margin": 3,
  // "scroll_beyond_last_line": "one_page",
  // "autoscroll_on_clicks": false,

  // ── Tabs ────────────────────────────────────────────────────────────

  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "all"
    // "inline_code_actions": true
  },
  // "tab_bar": {
  //   "show": true,
  //   "show_nav_history_buttons": true,
  //   "show_tab_bar_buttons": true
  // },
  // "max_tabs": null,
  // "preview_tabs": {
  //   "enabled": true,
  //   "enable_preview_from_project_panel": true,
  //   "enable_preview_from_file_finder": false,
  //   "enable_preview_from_multibuffer": true,
  //   "enable_preview_file_from_code_navigation": true
  // },
  // "when_closing_with_no_tabs": "platform_default",

  // ── Toolbar & Status Bar ──────────────────────────────────────────

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true
    // "agent_review": true,
    // "code_actions": false
  },
  // "status_bar": {
  //   "active_language_button": true,
  //   "cursor_position_button": true,
  //   "line_endings_button": false
  // },
  // "line_indicator_format": "short",  // short, long

  // ── File Finder ─────────────────────────────────────────────────────

  "file_finder": {
    "modal_max_width": "medium"
    // "file_icons": true,
    // "skip_focus_for_active_in_search": true
  },

  // ── Text Wrapping ─────────────────────────────────────────────────

  // "soft_wrap": "none",              // none, editor_width, preferred_line_length, bounded
  // "preferred_line_length": 80,
  // "show_wrap_guides": true,

  // ── Indentation & Whitespace ──────────────────────────────────────

  // "hard_tabs": false,
  // "tab_size": 4,
  // "show_whitespaces": "selection",  // all, selection, none, boundary
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
    // "line_width": 1,
    // "active_line_width": 1,
    // "background_coloring": "disabled"
  },

  // ── Inlay Hints ─────────────────────────────────────────────────────

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
    // "toggle_on_modifiers_press": null
  },

  // ── Code Completion ─────────────────────────────────────────────────

  // "show_completions_on_input": true,
  // "show_completion_documentation": true,
  // "snippet_sort_order": "inline",   // top, inline, bottom, none
  // "completions": {
  //   "words": "fallback",            // enabled, fallback, disabled
  //   "words_min_length": 3,
  //   "lsp": true,
  //   "lsp_fetch_timeout_ms": 0,
  //   "lsp_insert_mode": "replace_suffix"
  // },

  // ── Code Intelligence ─────────────────────────────────────────────

  // "enable_language_server": true,
  // "semantic_tokens": "off",         // off, combined, full
  // "document_folding_ranges": "off", // off, on
  // "document_symbols": "off",        // off, on
  // "hover_popover_enabled": true,
  // "hover_popover_delay": 300,
  // "go_to_definition_fallback": "find_all_references",
  // "auto_signature_help": false,
  // "show_signature_help_after_edits": false,
  // "lsp_highlight_debounce": 75,
  // "lsp_document_colors": "inlay",   // inlay, background, border, none

  // ── Diagnostics ─────────────────────────────────────────────────────

  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 2,
      "max_severity": "hint"
    }
    // "include_warnings": true
  },
  // "diagnostics_max_severity": null,

  // ── Search ──────────────────────────────────────────────────────────

  // "search": {
  //   "button": true,
  //   "whole_word": false,
  //   "case_sensitive": false,
  //   "include_ignored": false,
  //   "regex": false,
  //   "center_on_match": false
  // },
  // "search_wrap": true,
  // "seed_search_query_from_cursor": "always",
  // "use_smartcase_search": false,

  // ── Git ─────────────────────────────────────────────────────────────

  "git": {
    "inline_blame": {
      "enabled": true
      // "delay_ms": null,
      // "show_commit_summary": null,
      // "min_column": null,
      // "padding": null
    }
    // "git_gutter": "tracked_files",
    // "gutter_debounce": null,
    // "branch_picker": { "show_author_name": false },
    // "hunk_style": "staged_hollow"
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
    "dock": "right"
  },
  // "diff_view_style": "split",       // unified, split

  // ── Panels ──────────────────────────────────────────────────────────

  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
    "default_width": 240,
    "entry_spacing": "comfortable",
    "file_icons": true,
    "folder_icons": true,
    "indent_size": 25,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "scrollbar": { "show": "never" },
    "show_diagnostics": "all",
    "indent_guides": { "show": "always" }
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
    "default_width": 300,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "indent_guides": { "show": "always" },
    "scrollbar": { "show": "never" }
  },
  "notification_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },

  // ── Terminal ────────────────────────────────────────────────────────

  "terminal": {
    "dock": "bottom",
    "font_family": "Monaspace Neon",
    "font_size": 12,
    "font_features": {
      "calt": true,
      "ss01": true, "ss02": true, "ss03": true, "ss04": true, "ss05": true,
      "ss06": true, "ss07": true, "ss08": true, "ss09": true,
      "liga": true
    },
    "env": {
      "EDITOR": "zed --wait"
    },
    "alternate_scroll": "on",
    "blinking": "on",
    "copy_on_select": false,
    "default_width": 640,
    "default_height": 320,
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default"
      }
    },
    "line_height": "comfortable",
    "option_as_meta": false,
    "button": true,
    "shell": "system",
    "toolbar": { "breadcrumbs": false },
    "working_directory": "current_project_directory",
    "scrollbar": { "show": "never" }
  },

  // ── Debugger ────────────────────────────────────────────────────────

  "debugger": {
    "dock": "right",
    "save_breakpoints": true,
    "button": true,
    "format_dap_log_messages": true,
    "log_dap_communications": true,
    "stepping_granularity": "line",
    "timeout": 2000
  },

  // ── AI / Agent ──────────────────────────────────────────────────────

  // "disable_ai": false,

  "agent": {
    "enabled": true,
    "button": true,
    "dock": "right",
    "default_width": 640,
    "default_height": 320,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-20250514"
    },
    "default_profile": "ask",
    "tool_permissions": {
      "default": "allow"
    },
    "profiles": {
      "agent": {
        "name": "Agent",
        "default_model": {
          "provider": "google",
          "model": "gemini-3-pro-preview"
        },
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "find_path": true,
          "grep": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "open": true,
          "read_file": true,
          "thinking": true,
          "terminal": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    }
  },
  "agent_servers": {
    "github-copilot-cli": { "type": "registry" },
    "claude-acp": { "type": "registry" }
  },

  // ── Edit Predictions (Copilot) ──────────────────────────────────────

  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager"
    // "disabled_globs": [],
    // "copilot": {
    //   "proxy": null,
    //   "proxy_no_verify": null,
    //   "enterprise_uri": null
    // }
  },
  // "show_edit_predictions": true,
  // "edit_predictions_disabled_in": [],
  // "features": { "edit_prediction_provider": "zed" },

  // ── Context Servers ─────────────────────────────────────────────────

  "context_servers": {
    "postgres-context-server": {
      "enabled": false,
      "settings": {
        "database_url": "postgresql://myuser:mypassword@localhost:5432/mydatabase"
      }
    }
  },

  // ── Languages ───────────────────────────────────────────────────────

  "languages": {
    "Go": {
      "wrap_guides": [80],
      "inlay_hints": {},
      "language_servers": ["gopls"]
    }
  },

  // ── LSP ─────────────────────────────────────────────────────────────

  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path", "stdout",
          "--show-stats=false",
          "--output.text.path="
        ]
      }
    },
    "lua-language-server": {
      "initialization_options": {
        "runtime.version": "LuaJIT",
        "diagnostics.globals": ["vim"],
        "workspace.checkThirdParty": false
      }
    }
  },
  // "global_lsp_settings": {
  //   "button": true,
  //   "request_timeout": 120,
  //   "notifications": { "dismiss_timeout_ms": 5000 }
  // },

  // ── File Types & Exclusions ─────────────────────────────────────────

  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.settings",
    "**/out",
    "**/bin",
    "**/.vscode",
    "**/node_modules"
  ],
  // "file_scan_inclusions": [".env*"],
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "json": ["json", "jsonc", "*.code-snippets"]
  },
  // "private_files": [],
  // "redact_private_values": false,

  // ── Mouse & Input ─────────────────────────────────────────────────

  // "hide_mouse": "on_typing_and_movement",
  // "double_click_in_multibuffer": "select",
  // "drag_and_drop_selection": { "enabled": true, "delay": 300 },
  // "middle_click_paste": true,       // Linux only
  // "allow_rewrap": "in_comments",    // in_comments, in_selections, anywhere
  // "jsx_tag_auto_close": { "enabled": true },

  // ── Multibuffer & Excerpts ────────────────────────────────────────

  // "expand_excerpt_lines": 5,
  // "excerpt_context_lines": 2,

  // ── Journal ───────────────────────────────────────────────────────

  // "journal": {
  //   "path": "~",
  //   "hour_format": "hour12"         // hour12, hour24
  // },

  // ── Node.js ───────────────────────────────────────────────────────

  // "node": {
  //   "ignore_system_version": false,
  //   "path": null,
  //   "npm_path": null
  // },
  // "load_direnv": "direct",          // shell_hook, direct, disabled

  // ── Network ───────────────────────────────────────────────────────

  // "proxy": null,

  // ── Auto Install Extensions ─────────────────────────────────────────

  "auto_install_extensions": {
    "html": true,
    "one-dark-pro": true,
    "toml": true,
    "dockerfile": true,
    "vue": true,
    "sql": true,
    "lua": true,
    "env": true,
    "golangci-lint": true,
    "fish": true,
    "postgres-context-server": true,
    "code-stats": true
  },

  // ── Telemetry ───────────────────────────────────────────────────────

  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
