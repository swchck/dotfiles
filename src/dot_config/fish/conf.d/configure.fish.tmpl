# Fish 4.5.0 shell environment configuration
# Sourced on every fish startup (interactive and non-interactive)

# ── Greeting ─────────────────────────────────────────────────────────

set fish_greeting ""

# ── Terminal protocols ───────────────────────────────────────────────
# Disable kitty keyboard protocol / xterm modifyOtherKey negotiation.
# When TUI apps (Claude Code, etc.) crash without restoring terminal state,
# fish leaves the protocol enabled and keypresses render as literal escape
# sequences (e.g. `[27u`, `[200~`) until the shell is restarted.
# fish_features is a universal var read at startup; the guard makes this idempotent.
if not contains no-keyboard-protocols $fish_features
    set -Ua fish_features no-keyboard-protocols
end

# ── Functions ───────────────────────────────────────────────────────
# Add subdirectories to fish_function_path for lazy autoloading.
# Functions are loaded on first call, not at startup.

for dir in ~/.config/fish/functions/*/
    if test -d "$dir"
        set -p fish_function_path $dir
    end
end

# ── Homebrew ─────────────────────────────────────────────────────────

{{ template "brew-shellenv-fish" . }}

set -gx HOMEBREW_NO_ANALYTICS 1
set -gx HOMEBREW_NO_ENV_HINTS 1
set -gx HOMEBREW_BAT 1
set -gx HOMEBREW_BUNDLE_DESCRIBE 1
# Opt into the compact internal JSON API (Homebrew 5.0+). Smaller payloads,
# faster `brew update` / `brew install`. Will become default in a future release.
set -gx HOMEBREW_USE_INTERNAL_API 1
set -gx MAS_NO_AUTO_INDEX 1
# set -gx HOMEBREW_NO_AUTO_UPDATE 1
# set -gx HOMEBREW_CLEANUP_MAX_AGE_DAYS 30
# set -gx HOMEBREW_DISPLAY_INSTALL_TIMES 1

# ── Cargo / Rust ─────────────────────────────────────────────────────

if test -f "$HOME/.cargo/env.fish"
    source "$HOME/.cargo/env.fish"
end

# ── Go ───────────────────────────────────────────────────────────────

set -gx GOPATH $HOME/.go
set -gx GOBIN $GOPATH/bin
set -gx GOMODCACHE $GOPATH/pkg/mod
fish_add_path $GOBIN
# GOTOOLDIR is resolved lazily — `go env GOTOOLDIR` is expensive (~30ms)
{{ if and (eq .machine_type "work") (hasKey . "gitlab") }}
# Private modules — skip proxy and checksum for work GitLab
set -gx GOPRIVATE "{{ .gitlab.url }}/*"
set -gx GONOSUMCHECK "{{ .gitlab.url }}/*"
{{ end -}}

# ── Node / NVM ───────────────────────────────────────────────────────

# set -gx NVM_DIR $HOME/.nvm

# ── Deno ─────────────────────────────────────────────────────────────

set -gx DENO_DIR $HOME/.deno

# ── Python / pipx ───────────────────────────────────────────────────

fish_add_path $HOME/.local/bin

# ── Ollama ───────────────────────────────────────────────────────────

# set -gx OLLAMA_HOST "127.0.0.1:11434"
# set -gx OLLAMA_MODELS $HOME/.ollama/models

# ── Editor ───────────────────────────────────────────────────────────

set -gx EDITOR nvim
set -gx VISUAL nvim

# Use bat as man pager with Monaspace font friendly formatting
set -gx MANPAGER "sh -c 'col -bx | bat -l man -p'"
set -gx MANROFFOPT "-c"

# ── fzf ──────────────────────────────────────────────────────────────

# Use fd instead of find
set -gx FZF_DEFAULT_COMMAND "fd --hidden --follow --exclude .git"
set -gx FZF_CTRL_T_COMMAND "fd --type f --hidden --follow --exclude .git"
set -gx FZF_ALT_C_COMMAND "fd --type d --hidden --follow --exclude .git"

# Default options: One Dark Pro colors, bat preview for files, eza for dirs
set -gx FZF_DEFAULT_OPTS "\
  --height=60% \
  --layout=reverse \
  --border \
  --info=inline \
  --color=bg+:#3e4452,bg:#282c34,spinner:#e5c07b,hl:#e06c75 \
  --color=fg:#abb2bf,header:#e06c75,info:#c678dd,pointer:#e5c07b \
  --color=marker:#61afef,fg+:#abb2bf,prompt:#c678dd,hl+:#e06c75 \
  --color=selected-bg:#3e4452 \
  --color=border:#636d83,label:#abb2bf"

set -gx FZF_CTRL_T_OPTS "\
  --preview 'bat --color=always --style=numbers --line-range=:500 {} 2>/dev/null || eza --icons --color=always {}'"

set -gx FZF_ALT_C_OPTS "\
  --preview 'eza --tree --level=2 --icons --color=always {}'"

# ── ripgrep ──────────────────────────────────────────────────────────

set -gx RIPGREP_CONFIG_PATH $HOME/.config/ripgrep/config

# ── Misc ─────────────────────────────────────────────────────────────

