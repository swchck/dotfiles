#!/usr/bin/env bash
{{ if not .ephemeral -}}

set -euo pipefail

{{ $linux := .packages.linux.common -}}

# ── Detect package manager ───────────────────────────────────────────

PM=""
if command -v apt-get &>/dev/null; then
    PM="apt"
elif command -v dnf &>/dev/null; then
    PM="dnf"
elif command -v pacman &>/dev/null; then
    PM="pacman"
fi

# ── Install system packages ──────────────────────────────────────────

if [ -n "$PM" ]; then
    echo "Installing system packages via $PM..."

    case "$PM" in
        apt)
            sudo apt-get update -qq
            sudo apt-get install -y -qq \
{{ range (dig "apt" "packages" (list) $linux) }}                {{ . }} \
{{ end }}                || true
            ;;
        dnf)
            sudo dnf install -y \
{{ range (dig "dnf" "packages" (list) $linux) }}                {{ . }} \
{{ end }}                || true
            ;;
        pacman)
            sudo pacman -Syu --noconfirm \
{{ range (dig "pacman" "packages" (list) $linux) }}                {{ . }} \
{{ end }}                || true
            ;;
    esac
else
    echo "No supported package manager found (apt/dnf/pacman), skipping system packages"
fi

# ── Install Homebrew packages (tools not in system repos) ────────────

if command -v brew &>/dev/null; then
    echo "Installing CLI tools via Homebrew..."
    brew install \
{{ range ($linux.brew | sortAlpha | uniq) }}        {{ . }} \
{{ end }}        2>/dev/null || true
else
    echo "Homebrew not available, installing tools via standalone installers..."

    # Fallback: standalone install scripts
{{ range $tool, $cmd := (dig "installers" (dict) $linux) }}
    if ! command -v {{ $tool }} &>/dev/null; then
        echo "Installing {{ $tool }}..."
        {{ $cmd }} || true
    fi
{{ end }}
fi

# ── Set fish as default shell ────────────────────────────────────────

FISH_PATH=$(command -v fish || true)
if [ -n "$FISH_PATH" ]; then
    if ! grep -q "$FISH_PATH" /etc/shells 2>/dev/null; then
        echo "$FISH_PATH" | sudo tee -a /etc/shells
    fi
    if [ "$SHELL" != "$FISH_PATH" ]; then
        sudo chsh -s "$FISH_PATH" "$(whoami)" || true
    fi
fi

{{ end -}}
