#!/usr/bin/env bash
{{ if not .ephemeral -}}

# Import secrets from age-encrypted file in chezmoi SOURCE into Keychain.
# Runs BEFORE apply so templates can access secrets via `security find-generic-password`.

set -uo pipefail

KEY_FILE="${HOME}/.config/chezmoi/key.txt"
SECRETS_AGE="{{ .chezmoi.sourceDir }}/dot_config/chezmoi/secrets.age"

if [ ! -f "$SECRETS_AGE" ]; then
    echo "No encrypted secrets file in source, skipping."
    exit 0
fi

if [ ! -f "$KEY_FILE" ]; then
    echo "No age key, skipping secrets import."
    exit 0
fi

if ! command -v age &>/dev/null; then
    echo "age not installed, skipping secrets import."
    exit 0
fi

echo "Importing secrets into Keychain..."

age -d -i "$KEY_FILE" "$SECRETS_AGE" 2>/dev/null | while IFS='=' read -r service value; do
    if [ -n "$service" ] && [ -n "$value" ] && [ "$service" != "age-secret-key" ]; then
        EXISTING=$(security find-generic-password -a "chezmoi" -s "$service" -w 2>/dev/null || true)
        if [ "$EXISTING" != "$value" ]; then
            security add-generic-password -a "chezmoi" -s "$service" -w "$value" -U 2>/dev/null || true
            echo "  Imported: $service"
        fi
    fi
done

echo "Secrets import complete."

{{ end -}}
