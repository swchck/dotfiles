  command: sudo sysctl -w net.inet.ip.ttl=65
ttl_off:
  command: sudo sysctl -w net.inet.ip.ttl=64
tracert:
  command: traceroute
path:
  command: echo $PATH | tr -s ":" "\n"
dl:
  command: cd ~/Downloads
g:
  command: git
override-dot:
  command: python3 ~/dotfiles/bin/dotfiles-local
git-conf:
  command: python3 ~/dotfiles/bin/git-config-manager
cat:
  command: ccat
gcane:
  command: git add . && git commit --amend --no-edit
gmc:
  command: git checkout $1 && git cherry-pick master && git checkout master && git reset HEAD~ --hard
...: 
